{
  "prompts": [
    "../.agents/commands"
  ],
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "openai-codex/gpt-5.4",
        "fallbackModels": [
          "openai-codex/gpt-5.5",
          "zai/glm-5.1",
          "zai/glm-5-turbo"
        ],
        "thinking": "medium"
      },
      "planner": {
        "model": "openai-codex/gpt-5.5",
        "fallbackModels": [
          "openai-codex/gpt-5.4",
          "zai/glm-5.1",
          "openai-codex/gpt-5.3-codex"
        ],
        "thinking": "xhigh"
      },
      "worker": {
        "model": "openai-codex/gpt-5.4",
        "fallbackModels": [
          "openai-codex/gpt-5.5",
          "openai-codex/gpt-5.4-mini"
        ],
        "thinking": "high"
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.5",
        "fallbackModels": [
          "openai-codex/gpt-5.4",
          "zai/glm-5.1",
          "openai-codex/gpt-5.3-codex"
        ],
        "thinking": "high"
      },
      "context-builder": {
        "model": "openai-codex/gpt-5.4-mini",
        "fallbackModels": [
          "openai-codex/gpt-5.4",
          "zai/glm-5-turbo"
        ],
        "thinking": "medium"
      },
      "researcher": {
        "model": "openai-codex/gpt-5.4",
        "fallbackModels": [
          "openai-codex/gpt-5.5",
          "zai/glm-5-turbo",
          "openai-codex/gpt-5.3-codex"
        ],
        "thinking": "xhigh"
      },
      "delegate": {
        "model": "openai-codex/gpt-5.4-mini",
        "fallbackModels": [
          "zai/glm-5-turbo",
          "openai-codex/gpt-5.3-codex"
        ],
        "thinking": "high"
      }
    }
  }
}